<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>User</title>

    <style>
      body {
        font-family: Arial, sans-serif;
        background: linear-gradient(135deg, #4e73df, #1cc88a);
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
        margin: 0;
      }

      form {
        background: #ffffff;
        padding: 30px 40px;
        border-radius: 12px;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
        width: 350px;
      }

      form label {
        display: block;
        margin-bottom: 15px;
      }

      form input {
        width: 100%;
        padding: 10px;
        border: 1px solid #ccc;
        border-radius: 8px;
        font-size: 14px;
        outline: none;
        transition: 0.3s;
      }

      form input:focus {
        border-color: #4e73df;
        box-shadow: 0 0 5px rgba(78, 115, 223, 0.5);
      }

      .btn {
        width: 100%;
        padding: 10px;
        border: none;
        border-radius: 8px;
        font-size: 16px;
        cursor: pointer;
        transition: 0.3s;
        margin-top: 10px;
      }

      .register-btn {
        background: #4e73df;
        color: white;
      }

      .register-btn:hover {
        background: #2e59d9;
      }

      .login-btn {
        background: #858796;
        color: white;
      }

      .login-btn:hover {
        background: #60616f;
      }

      .login-link {
        text-align: center;
        margin-top: 15px;
      }

      .login-link a {
        text-decoration: none;
        color: #4e73df;
        font-weight: bold;
      }

      .login-link a:hover {
        text-decoration: underline;
      }
    </style>
  </head>

  <body>
    <form action="/signup" method="post">
      <h2 style="text-align: center; margin-bottom: 20px">User Registration</h2>

      <label>
        <input type="text" name="name" placeholder="Full Name" required />
      </label>

      <label>
        <input type="number" name="age" placeholder="Age" required />
      </label>

      <label>
        <input type="email" name="email" placeholder="Email" required />
      </label>

      <label>
        <input type="text" name="mobile" placeholder="Mobile Number" />
      </label>

      <label>
        <input type="text" name="address" placeholder="Address" required />
      </label>

      <label>
        <input
          type="text"
          name="aadharCardNumber"
          placeholder="Aadhar Card Number"
          required
        />
      </label>

      <label>
        <input
          type="password"
          name="password"
          placeholder="Password"
          required
        />
      </label>

      <button type="submit" class="btn register-btn">Register</button>

      <!-- Login Button -->
      <button
        type="button"
        class="btn login-btn"
        onclick="window.location.href='/login'"
      >
        Login
      </button>

      <!-- Alternative small link -->
      <div class="login-link">
        Already have an account?
        <a href="/login">Login here</a>
      </div>
    </form>
  </body>
</html>
